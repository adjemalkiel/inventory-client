# Template committé pour le frontend. Copiez-le en `.env` (ignoré par Git)
# puis renseignez vos valeurs locales. Voir vite.config.ts et
# src/lib/api/http.ts pour l'usage de chaque variable.

# Backend Django. "/api/" + le proxy Vite en dev, URL publique complète en prod.
PUBLIC_API_URL=/api/

# Optionnel : Google Gemini pour les features IA. Laissez vide sinon.
GEMINI_API_KEY=

# Optionnel : "true" pour désactiver le HMR du dev server Vite.
DISABLE_HMR=false
